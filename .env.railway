# ── GPA ERP Frontend — Railway Environment Variables ─────────────────────────
# Set these in Railway → your frontend service → Variables tab.
#
# IMPORTANT: NEXT_PUBLIC_API_URL must also be set as a BUILD variable
# (Railway → Service → Settings → Build → Environment Variables)
# because Next.js bakes it into the JS bundle at build time.

NEXT_PUBLIC_API_URL=https://YOUR_BACKEND_URL.up.railway.app/api
